  m_Script: {fileID: 11500000, guid: 02dcf0005b8a2744eb49f653a12442d2, type: 3}
  m_Name: Dialogue_Pasar
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue.DialogueData
  _dialogueList:
  - state: 0
    messages:
    - actor: Ahmad
      message: Pak RT, saya melihat banyak sampah baru di sini. aku mendeteksinya
        sebagai sampah yang sulit diurai
    - actor: Pak RT
      message: Betul, Ahmad. Itu adalah sampah Residu, pastikan kamu memasukkannya
        ke tong warna Abu-abu. Tapi hati-hati, jalan utamanya tertutup rintangan
        barikade sampah raksasa!
    - actor: Ahmad
      message: Tidak masalah. Aku akan menggunakan sarung tanganku untuk menjadi
        penghancur dan membuka jalan itu.
  - state: 1
    messages:
    - actor: Ahmad
      message: Pak RT, saya melihat banyak sampah baru di sini. aku mendeteksinya
        sebagai sampah yang sulit diurai
    - actor: Pak RT
      message: Betul, Ahmad. Itu adalah sampah Residu, pastikan kamu memasukkannya
        ke tong warna Abu-abu. Tapi hati-hati, jalan utamanya tertutup rintangan
        barikade sampah raksasa!
    - actor: Ahmad
      message: Tidak masalah. Aku akan menggunakan sarung tanganku untuk menjadi
        penghancur dan membuka jalan itu.
  - state: 2
    messages:
    - actor: Ahmad
      message: Saya sudah selesai membersihkan Pasar, Pak!
    - actor: Pak RT
      message: Terima kasih Ahmad, mari kita lanjut ke Pabrik
