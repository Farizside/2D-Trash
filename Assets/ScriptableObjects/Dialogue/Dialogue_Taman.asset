%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dcf0005b8a2744eb49f653a12442d2, type: 3}
  m_Name: Dialogue_Taman
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue.DialogueData
  _dialogueList:
  - state: 0
    messages:
    - actor: Ahmad
      message: Permisi, Pak RT. Maaf saya baru kembali. Apa yang sebenarnya terjadi
        dengan Desa Gresik?
    - actor: Pak RT
      message: Seperti yang kamu lihat, warga mulai malas membuang sampah pada tempatnya,
        apalagi memilahnya dan Bapak tidak sanggup membersihkannya sendirian.
    - actor: Ahmad
      message: Tenang, Pak! Saya akan turun tangan langsung. Mari kita mulai bersihkan
        desa ini, saya akan mulai dari memulihkan area Taman!
  - state: 1
    messages:
    - actor: Ahmad
      message: Kondisinya parah sekali. Pak RT, sebagai permulaan, apa saja jenis
        sampah dasar yang harus saya pisahkan di sini?
    - actor: Pak RT
      message: Tolong pisahkan menjadi tiga ya, Nak. Masukkan sampah Organik ke Tong
        Hijau, Anorganik/Plastik ke Tong Kuning, dan bungkus Kertas ke Tong Biru.
    - actor: Ahmad
      message: Dimengerti, Pak! saya akan membersihkan dan memperindah nya!
  - state: 2
    messages:
    - actor: Ahmad
      message: Saya sudah bersihkan taman ini Pak!
    - actor: Pak RT
      message: Terima kasih, Nak. Sekarang kita lanjut ke Pasar!
